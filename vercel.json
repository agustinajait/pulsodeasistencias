{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/api-server build && pnpm --filter @workspace/cpi-sistema build",
  "outputDirectory": "artifacts/cpi-sistema/dist/public",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api" },
    { "src": "/login", "dest": "/index.html" },
    { "src": "/admin", "dest": "/index.html" },
    { "src": "/sala", "dest": "/index.html" },
    { "src": "/reportes", "dest": "/index.html" },
    { "src": "/servicios", "dest": "/index.html" },
    { "src": "/casos", "dest": "/index.html" },
    { "src": "/informes", "dest": "/index.html" },
    { "src": "/configuracion", "dest": "/index.html" },
    { "src": "/oportunai", "dest": "/index.html" },
    { "src": "/talentos", "dest": "/index.html" },
    { "src": "/calendario", "dest": "/index.html" },
    { "src": "/planificaciones", "dest": "/index.html" },
    { "src": "/diagnostico", "dest": "/index.html" },
    { "src": "/check-in/(.*)", "dest": "/index.html" },
    { "src": "/docs/(.*)", "dest": "/index.html" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/korai-logo.png", "dest": "/korai-logo.png" },
    { "src": "/hero-video.mp4", "dest": "/hero-video.mp4" },
    { "src": "/landing.html", "dest": "/landing.html" },
    { "src": "/", "dest": "/landing.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
